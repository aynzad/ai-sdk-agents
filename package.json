{
  "name": "ai-sdk-agents",
  "version": "0.0.1",
  "description": "Multi-agent orchestration for Vercel AI SDK — handoffs, guardrails, and tracing",
  "author": "Alireza Esfahani <alireza@esfahani.dev>",
  "type": "module",
  "main": "./dist/ai-sdk-agents.cjs",
  "module": "./dist/ai-sdk-agents.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/ai-sdk-agents.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/ai-sdk-agents.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "build:types": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "keywords": [
    "ai",
    "agents",
    "ai-sdk",
    "vercel",
    "multi-agent",
    "handoffs",
    "guardrails",
    "orchestration",
    "llm",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aynzad/ai-sdk-agents"
  },
  "homepage": "https://github.com/aynzad/ai-sdk-agents#readme",
  "bugs": {
    "url": "https://github.com/aynzad/ai-sdk-agents/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "ai": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "ai": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "zod": "^3.24.0"
  }
}